# TELEGRAM_TOKEN: Your Telegram Bot Token from @BotFather
TELEGRAM_TOKEN=
# CHAT_ID: Your Telegram Chat ID from @userinfobot
CHAT_ID=
# PORT: The port the server will run on (default 3000)
PORT=3000
# JWT_SECRET: A strong secret key for signing JWT tokens
JWT_SECRET=
# ADMIN_SETUP_KEY: A secret key to allow creating the first admin user via /api/auth/setup-admin
ADMIN_SETUP_KEY=
# ALLOWED_ORIGINS: Comma-separated list of allowed origins for CORS (e.g., https://your-site.com)
ALLOWED_ORIGINS=
